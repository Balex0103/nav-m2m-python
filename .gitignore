# .gitignore
# ====================================================================
# Python cache és belső futtató környezetek
# ====================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# ====================================================================
# IDE / Fejlesztői környezet és macOS rendszerfájlok
# ====================================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ====================================================================
# GDPR KRITIKUS KIZÁRÁSOK - Generált céges XML adatok és SAP exportok
# ====================================================================
*.xml
sap_export/
mock_data/

# ====================================================================
# Érzékeny hitelesítési adatok, kulcsok és helyi cache fájlok
# ====================================================================
.env
nav_verzio_cache.json
*.env

# ====================================================================
# Tranzakciós és Rendszer szintű naplófájlok (Logs)
# ====================================================================
logs/
*.log