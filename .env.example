# .env.example
# ====================================================================
# NAV M2M ASSZISZTENS - KÖRNYEZETI VÁLTOZÓK MINTAFÁJLA
# Másold le ezt a fájlt .env néven a projekt gyökerébe, és töltsd ki!
# A .env fájl szigorúan titkos, a .gitignore automatikusan kizárja!
# ====================================================================

# Hivatalos technikai felhasználói adatok (Online Számla / eÁFA felületről)
NAV_TECH_USER=IDE_A_VALODI_TECHNIKAI_FELHASZNALO
NAV_PASSWORD=IDE_A_VALODI_JELSZO
NAV_SIGN_KEY=IDE_A_VALODI_SIGN_KEY
NAV_EXCHANGE_KEY=IDE_A_VALODI_EXCHANGE_KEY

# Vállalati adatok
NAV_TAX_NUMBER=12345678
NAV_ENVIRONMENT=TEST

# Egyedi szoftver-integrációs azonosítók (opcionális vállalati bevezetéshez)
M2M_SOFTWARE_ID=HU1234567890123456
M2M_DEV_NAME=Belso Vallalati Integracio Kft.
M2M_DEV_CONTACT=m2m-support@company.hu
M2M_DEV_TAX_NUMBER=12345678